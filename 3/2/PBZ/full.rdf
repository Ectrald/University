<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/math#"
     xml:base="http://example.org/math"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/math">
        <owl:imports rdf:resource="http://example.org/philosophy"/>
        <owl:imports rdf:resource="http://example.org/physics"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/math#associatedWith -->

    <owl:ObjectProperty rdf:about="http://example.org/math#associatedWith">
        <rdfs:domain rdf:resource="http://example.org/math#Mathematician"/>
        <rdfs:range rdf:resource="http://example.org/math#Institution"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#authoredWork -->

    <owl:ObjectProperty rdf:about="http://example.org/math#authoredWork">
        <rdfs:domain rdf:resource="http://example.org/math#Philosopher"/>
        <rdfs:range rdf:resource="http://example.org/math#PhilosophicalWork"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#belongsToEra -->

    <owl:ObjectProperty rdf:about="http://example.org/math#belongsToEra">
        <owl:inverseOf rdf:resource="http://example.org/math#hasMathematician"/>
        <rdfs:domain rdf:resource="http://example.org/math#Mathematician"/>
        <rdfs:range rdf:resource="http://example.org/math#HistoricalEra"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#developedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#developedBy">
        <rdfs:domain rdf:resource="http://example.org/math#Theory"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#discoveredLaw -->

    <owl:ObjectProperty rdf:about="http://example.org/math#discoveredLaw">
        <rdfs:domain rdf:resource="http://example.org/math#Physicist"/>
        <rdfs:range rdf:resource="http://example.org/math#PhysicalLaw"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#establishedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#establishedBy">
        <rdfs:domain rdf:resource="http://example.org/math#ScientificSchool"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#formulatedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#formulatedBy">
        <rdfs:domain rdf:resource="http://example.org/math#Theorem"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#foundedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#foundedBy">
        <rdfs:domain rdf:resource="http://example.org/math#BranchOfMathematics"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#hasMathematician -->

    <owl:ObjectProperty rdf:about="http://example.org/math#hasMathematician"/>
    


    <!-- http://example.org/math#introducedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#introducedBy">
        <rdfs:domain rdf:resource="http://example.org/math#MathematicalConcept"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#inventedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#inventedBy">
        <rdfs:domain rdf:resource="http://example.org/math#MathematicalMethod"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#popularizedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#popularizedBy">
        <rdfs:domain rdf:resource="http://example.org/math#NumberSystem"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#studiedConcept -->

    <owl:ObjectProperty rdf:about="http://example.org/math#studiedConcept">
        <rdfs:domain rdf:resource="http://example.org/math#Physicist"/>
        <rdfs:range rdf:resource="http://example.org/math#PhysicalConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/math#writtenBy -->

    <owl:ObjectProperty rdf:about="http://example.org/math#writtenBy">
        <rdfs:domain rdf:resource="http://example.org/math#ScientificWork"/>
        <rdfs:range rdf:resource="http://example.org/math#Mathematician"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/math#branchName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#branchName">
        <rdfs:domain rdf:resource="http://example.org/math#BranchOfMathematics"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#conceptName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#conceptName">
        <rdfs:domain rdf:resource="http://example.org/math#MathematicalConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#eraName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#eraName">
        <rdfs:domain rdf:resource="http://example.org/math#HistoricalEra"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#hasName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#hasName">
        <rdfs:domain rdf:resource="http://example.org/math#Mathematician"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#institutionName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#institutionName">
        <rdfs:domain rdf:resource="http://example.org/math#Institution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#lawName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#lawName">
        <rdfs:domain rdf:resource="http://example.org/math#PhysicalLaw"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#methodName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#methodName">
        <rdfs:domain rdf:resource="http://example.org/math#MathematicalMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#schoolName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#schoolName">
        <rdfs:domain rdf:resource="http://example.org/math#ScientificSchool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#systemName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#systemName">
        <rdfs:domain rdf:resource="http://example.org/math#NumberSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#theoremName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#theoremName">
        <rdfs:domain rdf:resource="http://example.org/math#Theorem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#theoryName -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#theoryName">
        <rdfs:domain rdf:resource="http://example.org/math#Theory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/math#workTitle -->

    <owl:DatatypeProperty rdf:about="http://example.org/math#workTitle">
        <rdfs:domain rdf:resource="http://example.org/math#ScientificWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/math#BranchOfMathematics -->

    <owl:Class rdf:about="http://example.org/math#BranchOfMathematics"/>
    


    <!-- http://example.org/math#HistoricalEra -->

    <owl:Class rdf:about="http://example.org/math#HistoricalEra"/>
    


    <!-- http://example.org/math#Institution -->

    <owl:Class rdf:about="http://example.org/math#Institution"/>
    


    <!-- http://example.org/math#MathematicalConcept -->

    <owl:Class rdf:about="http://example.org/math#MathematicalConcept"/>
    


    <!-- http://example.org/math#MathematicalMethod -->

    <owl:Class rdf:about="http://example.org/math#MathematicalMethod"/>
    


    <!-- http://example.org/math#Mathematician -->

    <owl:Class rdf:about="http://example.org/math#Mathematician"/>
    


    <!-- http://example.org/math#NumberSystem -->

    <owl:Class rdf:about="http://example.org/math#NumberSystem"/>
    


    <!-- http://example.org/math#Philosopher -->

    <owl:Class rdf:about="http://example.org/math#Philosopher"/>
    


    <!-- http://example.org/math#PhilosophicalWork -->

