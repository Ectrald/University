        <foundedBy rdf:resource="http://example.org/math#Leibniz"/>
        <branchName>Математический анализ</branchName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Meditations -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Meditations">
