    <!-- http://example.org/math#Pythagoras -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Pythagoras">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <rdf:type rdf:resource="http://example.org/math#Philosopher"/>
        <belongsToEra rdf:resource="http://example.org/math#Antiquity"/>
        <hasName>Пифагор</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#PythagorasTheorem -->

    <owl:NamedIndividual rdf:about="http://example.org/math#PythagorasTheorem">
        <rdf:type rdf:resource="http://example.org/math#Theorem"/>
        <formulatedBy rdf:resource="http://example.org/math#Pythagoras"/>
