    <owl:Class rdf:about="http://example.org/math#PhysicalLaw"/>
    


    <!-- http://example.org/math#Physicist -->

    <owl:Class rdf:about="http://example.org/math#Physicist"/>
    


    <!-- http://example.org/math#ScientificSchool -->

    <owl:Class rdf:about="http://example.org/math#ScientificSchool"/>
    


    <!-- http://example.org/math#ScientificWork -->

    <owl:Class rdf:about="http://example.org/math#ScientificWork"/>
    


    <!-- http://example.org/math#Theorem -->

    <owl:Class rdf:about="http://example.org/math#Theorem"/>
    


    <!-- http://example.org/math#Theory -->

    <owl:Class rdf:about="http://example.org/math#Theory"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/math#AlKhwarizmi -->

    <owl:NamedIndividual rdf:about="http://example.org/math#AlKhwarizmi">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <hasName>аль-Хорезми</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#AlbertEinstein -->

    <owl:NamedIndividual rdf:about="http://example.org/math#AlbertEinstein">
        <rdf:type rdf:resource="http://example.org/math#Physicist"/>
        <belongsToEra rdf:resource="http://example.org/math#ModernEra"/>
        <hasName>Альберт Эйнштейн</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Algorithm -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Algorithm">
        <rdf:type rdf:resource="http://example.org/math#MathematicalConcept"/>
        <introducedBy rdf:resource="http://example.org/math#AlKhwarizmi"/>
        <conceptName>Алгоритм</conceptName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#AnalyticalGeometry -->

    <owl:NamedIndividual rdf:about="http://example.org/math#AnalyticalGeometry">
        <rdf:type rdf:resource="http://example.org/math#BranchOfMathematics"/>
        <foundedBy rdf:resource="http://example.org/math#Descartes"/>
        <branchName>Аналитическая геометрия</branchName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Antiquity -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Antiquity">
        <rdf:type rdf:resource="http://example.org/math#HistoricalEra"/>
        <eraName>Античность</eraName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Archimedes -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Archimedes">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <rdf:type rdf:resource="http://example.org/math#Physicist"/>
        <belongsToEra rdf:resource="http://example.org/math#Antiquity"/>
        <discoveredLaw rdf:resource="http://example.org/math#ArchimedesPrinciple"/>
        <hasName>Архимед</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#ArchimedesPrinciple -->

    <owl:NamedIndividual rdf:about="http://example.org/math#ArchimedesPrinciple">
        <rdf:type rdf:resource="http://example.org/math#PhysicalLaw"/>
        <lawName>Закон Архимеда</lawName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Aristotle -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Aristotle">
        <rdf:type rdf:resource="http://example.org/math#Philosopher"/>
        <belongsToEra rdf:resource="http://example.org/math#Antiquity"/>
        <hasName>Аристотель</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Arithmetica -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Arithmetica">
        <rdf:type rdf:resource="http://example.org/math#ScientificWork"/>
        <writtenBy rdf:resource="http://example.org/math#Diophantus"/>
        <workTitle>Арифметика</workTitle>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#BinarySystem -->

    <owl:NamedIndividual rdf:about="http://example.org/math#BinarySystem">
        <rdf:type rdf:resource="http://example.org/math#NumberSystem"/>
        <popularizedBy rdf:resource="http://example.org/math#Leibniz"/>
        <systemName>Двоичная система счисления</systemName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Bourbaki -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Bourbaki">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <hasName>Николя Бурбаки</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#BourbakiGroup -->

    <owl:NamedIndividual rdf:about="http://example.org/math#BourbakiGroup">
        <rdf:type rdf:resource="http://example.org/math#ScientificSchool"/>
        <establishedBy rdf:resource="http://example.org/math#Bourbaki"/>
        <schoolName>Группа Бурбаки</schoolName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Cambridge -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Cambridge">
        <rdf:type rdf:resource="http://example.org/math#Institution"/>
        <institutionName>Кембриджский университет</institutionName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Cantor -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Cantor">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <hasName>Георг Кантор</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#CoordinateMethod -->

    <owl:NamedIndividual rdf:about="http://example.org/math#CoordinateMethod">
        <rdf:type rdf:resource="http://example.org/math#MathematicalMethod"/>
        <inventedBy rdf:resource="http://example.org/math#Descartes"/>
        <methodName>Метод координат</methodName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#DecimalSystem -->

    <owl:NamedIndividual rdf:about="http://example.org/math#DecimalSystem">
        <rdf:type rdf:resource="http://example.org/math#NumberSystem"/>
        <popularizedBy rdf:resource="http://example.org/math#AlKhwarizmi"/>
        <systemName>Десятичная система</systemName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Descartes -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Descartes">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <rdf:type rdf:resource="http://example.org/math#Philosopher"/>
        <rdf:type rdf:resource="http://example.org/math#Physicist"/>
        <authoredWork rdf:resource="http://example.org/math#Meditations"/>
        <belongsToEra rdf:resource="http://example.org/math#ModernEra"/>
        <studiedConcept rdf:resource="http://example.org/math#Optics"/>
        <hasName>Рене Декарт</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#DiagonalMethod -->

    <owl:NamedIndividual rdf:about="http://example.org/math#DiagonalMethod">
        <rdf:type rdf:resource="http://example.org/math#MathematicalMethod"/>
        <inventedBy rdf:resource="http://example.org/math#Cantor"/>
        <methodName>Диагональный метод</methodName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Diophantus -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Diophantus">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <belongsToEra rdf:resource="http://example.org/math#Antiquity"/>
        <hasName>Диофант</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Elements -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Elements">
        <rdf:type rdf:resource="http://example.org/math#ScientificWork"/>
        <writtenBy rdf:resource="http://example.org/math#Euclid"/>
        <workTitle>Начала</workTitle>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Euclid -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Euclid">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <belongsToEra rdf:resource="http://example.org/math#Antiquity"/>
        <hasName>Евклид</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Fermat -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Fermat">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <belongsToEra rdf:resource="http://example.org/math#ModernEra"/>
        <hasName>Пьер Ферма</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#FermatTheorem -->

    <owl:NamedIndividual rdf:about="http://example.org/math#FermatTheorem">
        <rdf:type rdf:resource="http://example.org/math#Theorem"/>
        <formulatedBy rdf:resource="http://example.org/math#Fermat"/>
        <theoremName>Великая теорема Ферма</theoremName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#IsaacNewton -->

    <owl:NamedIndividual rdf:about="http://example.org/math#IsaacNewton">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <rdf:type rdf:resource="http://example.org/math#Physicist"/>
        <associatedWith rdf:resource="http://example.org/math#Cambridge"/>
        <belongsToEra rdf:resource="http://example.org/math#ModernEra"/>
        <discoveredLaw rdf:resource="http://example.org/math#LawOfGravity"/>
        <studiedConcept rdf:resource="http://example.org/math#Optics"/>
        <hasName>Исаак Ньютон</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#LawOfGravity -->

    <owl:NamedIndividual rdf:about="http://example.org/math#LawOfGravity">
        <rdf:type rdf:resource="http://example.org/math#PhysicalLaw"/>
        <lawName>Закон всемирного тяготения</lawName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#Leibniz -->

    <owl:NamedIndividual rdf:about="http://example.org/math#Leibniz">
        <rdf:type rdf:resource="http://example.org/math#Mathematician"/>
        <rdf:type rdf:resource="http://example.org/math#Philosopher"/>
        <authoredWork rdf:resource="http://example.org/math#Monadology"/>
        <belongsToEra rdf:resource="http://example.org/math#ModernEra"/>
        <hasName>Готфрид Лейбниц</hasName>
    </owl:NamedIndividual>
    


    <!-- http://example.org/math#MathematicalAnalysis -->

    <owl:NamedIndividual rdf:about="http://example.org/math#MathematicalAnalysis">
        <rdf:type rdf:resource="http://example.org/math#BranchOfMathematics"/>
