<http://example.org/math> rdf:type owl:Ontology ;
                           owl:imports <http://example.org/philosophy> ,
                                       <http://example.org/physics> .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/math#associatedWith
:associatedWith rdf:type owl:ObjectProperty ;
                rdfs:domain :Mathematician ;
                rdfs:range :Institution .


###  http://example.org/math#authoredWork
:authoredWork rdf:type owl:ObjectProperty ;
              rdfs:domain :Philosopher ;
              rdfs:range :PhilosophicalWork .


###  http://example.org/math#belongsToEra
:belongsToEra rdf:type owl:ObjectProperty ;
              owl:inverseOf :hasMathematician ;
              rdfs:domain :Mathematician ;
              rdfs:range :HistoricalEra .


###  http://example.org/math#developedBy
:developedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :Theory ;
             rdfs:range :Mathematician .


###  http://example.org/math#discoveredLaw
:discoveredLaw rdf:type owl:ObjectProperty ;
               rdfs:domain :Physicist ;
               rdfs:range :PhysicalLaw .


###  http://example.org/math#establishedBy
:establishedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :ScientificSchool ;
               rdfs:range :Mathematician .


###  http://example.org/math#formulatedBy
:formulatedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Theorem ;
              rdfs:range :Mathematician .


###  http://example.org/math#foundedBy
:foundedBy rdf:type owl:ObjectProperty ;
           rdfs:domain :BranchOfMathematics ;
           rdfs:range :Mathematician .


###  http://example.org/math#hasMathematician
:hasMathematician rdf:type owl:ObjectProperty .


###  http://example.org/math#introducedBy
:introducedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :MathematicalConcept ;
              rdfs:range :Mathematician .


###  http://example.org/math#inventedBy
:inventedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :MathematicalMethod ;
            rdfs:range :Mathematician .


###  http://example.org/math#popularizedBy
:popularizedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :NumberSystem ;
               rdfs:range :Mathematician .


###  http://example.org/math#studiedConcept
:studiedConcept rdf:type owl:ObjectProperty ;
                rdfs:domain :Physicist ;
                rdfs:range :PhysicalConcept .


###  http://example.org/math#writtenBy
:writtenBy rdf:type owl:ObjectProperty ;
           rdfs:domain :ScientificWork ;
           rdfs:range :Mathematician .


