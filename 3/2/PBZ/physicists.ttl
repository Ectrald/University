@prefix : <http://example.org/math#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/physics> a owl:Ontology .

### --- КЛАССЫ И СВОЙСТВА --- ###
:Physicist a owl:Class .
:PhysicalLaw a owl:Class .
:PhysicalConcept a owl:Class .

:lawName a owl:DatatypeProperty ; rdfs:domain :PhysicalLaw ; rdfs:range xsd:string .
:discoveredLaw a owl:ObjectProperty ; rdfs:domain :Physicist ; rdfs:range :PhysicalLaw .
:studiedConcept a owl:ObjectProperty ; rdfs:domain :Physicist ; rdfs:range :PhysicalConcept .

### --- ЭКЗЕМПЛЯРЫ (Пересечения с математикой) --- ###
:IsaacNewton a owl:NamedIndividual, :Physicist .
:Archimedes a owl:NamedIndividual, :Physicist .
:Descartes a owl:NamedIndividual, :Physicist . 

### --- НОВЫЕ ЭКЗЕМПЛЯРЫ --- ###
:AlbertEinstein a owl:NamedIndividual, :Physicist ;
    :hasName "Альберт Эйнштейн"^^xsd:string ; :belongsToEra :ModernEra . 

:LawOfGravity a owl:NamedIndividual, :PhysicalLaw ;
    :lawName "Закон всемирного тяготения"^^xsd:string .
:IsaacNewton :discoveredLaw :LawOfGravity .

:ArchimedesPrinciple a owl:NamedIndividual, :PhysicalLaw ;
    :lawName "Закон Архимеда"^^xsd:string .
:Archimedes :discoveredLaw :ArchimedesPrinciple .

:Optics a owl:NamedIndividual, :PhysicalConcept ;
    :conceptName "Оптика"^^xsd:string . # Переиспользуем conceptName из базы математиков
:Descartes :studiedConcept :Optics .
:IsaacNewton :studiedConcept :Optics .