@startuml
skinparam monochrome true

actor User
participant "Streamlit UI" as UI
participant "FastAPI" as API
participant "CorpusController" as Ctrl
participant "CorpusManager" as Manager
participant "TextProcessor" as Proc

User -> UI : Вводит текст и нажимает "Analyze"
UI -> API : POST /api/analyze
API -> Ctrl : analyze_text(text)
Ctrl -> Manager : analyze_text(text)
Manager -> Proc : process_text(text)
Proc -> Proc : spaCy (очистка, токенизация, POS)
return Кортеж токенов и NLP-данных
Manager -> Manager : Подсчет агрегатной статистики
return Словарь со статистикой
return Словарь со статистикой
return JSON Response
UI -> User : Отрисовка результатов (графики и метрики)
@enduml
