@startuml
skinparam monochrome true

actor User
participant "Streamlit UI" as UI
participant "FastAPI" as API
participant "CorpusController" as Ctrl
participant "ConcordanceAnalyzer" as Conc
database "Database" as DB

User -> UI : Вводит лемму и размер окна
UI -> API : GET /api/concordance/kwic?lemma=word&window=5
API -> Ctrl : get_kwic("word", 5)
Ctrl -> Conc : get_kwic("word", 5)
Conc -> DB : Поиск слова по лемме
DB --> Conc: Найденные слова
Conc -> DB : Выборка соседних контекстных слов
DB --> Conc: Контекст (слова)
return Список KWIC-словарей
return KWIC-результаты
return JSON результаты
UI -> User : Отрисовка таблицы KWIC

UI -> API : GET /api/concordance/collocates?lemma=word&window=5
API -> Ctrl : get_collocates("word", 5)
Ctrl -> Conc : get_collocations_in_context("word", 5)
Conc -> DB : Выборка коллокатов (связанных слов)
return Словарь коллокатов и частот
return Результат
return JSON результаты
UI -> User : Отрисовка таблицы коллокатов
@enduml
