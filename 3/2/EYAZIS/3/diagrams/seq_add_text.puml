@startuml
skinparam monochrome true

actor User
participant "Streamlit UI" as UI
participant "FastAPI" as API
participant "CorpusController" as Ctrl
participant "CorpusManager" as Manager
database "Database (SQLite)" as DB

User -> UI : Вводит текст и нажимает "Add Text"
UI -> API : POST /api/texts
API -> Ctrl : add_text(title, content, ...)
Ctrl -> Manager : add_text(...)
Manager -> DB : session.add(Document)
Manager -> DB : session.commit()
return Document Info
return Словарь {success, message, doc_id}
return JSON response
UI -> User : Вывод сообщения об успехе
@enduml
